# AI Orchestrator Service Environment Variables
ENV=development
PORT=8086
LOG_LEVEL=info

# Secrets service for retrieving user API keys
SECRETS_SERVICE_URL=http://localhost:8088

# Default model versions
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
GEMINI_DEFAULT_MODEL=gemini-1.5-pro

# GCP Pub/Sub (production only)
# GCP_PROJECT_ID=
# PUBSUB_AI_REQUESTS_TOPIC=ai-requests
# PUBSUB_AI_RESPONSES_TOPIC=ai-responses
