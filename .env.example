# ============================================================
# Pote - Local Development Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# ---------- General ----------
ENV=development
LOG_LEVEL=debug

# ---------- PostgreSQL ----------
POSTGRES_USER=pote
POSTGRES_PASSWORD=pote_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------- Per-Service Databases ----------
AUTH_DB_NAME=pote_auth
USER_DB_NAME=pote_users
CHAT_DB_NAME=pote_chats
MESSAGE_DB_NAME=pote_messages
SECRETS_DB_NAME=pote_secrets
AUDIT_DB_NAME=pote_audit
NOTIFICATION_DB_NAME=pote_notifications

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT ----------
JWT_SECRET=your-dev-jwt-secret-change-in-production
JWT_ISSUER=pote
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback/google

# ---------- Service Ports ----------
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
CHAT_SERVICE_PORT=8083
MESSAGE_SERVICE_PORT=8084
REALTIME_SERVICE_PORT=8085
AI_ORCHESTRATOR_PORT=8086
NOTIFICATION_SERVICE_PORT=8087
SECRETS_SERVICE_PORT=8088
AUDIT_SERVICE_PORT=8089

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8085

# ---------- GCP (Production Only) ----------
# GCP_PROJECT_ID=
# GCP_REGION=
